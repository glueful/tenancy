{
    "name": "glueful/tenancy",
    "description": "Shared-database, row-level multi-tenancy for Glueful (tenant resolution, scoping, enforcement).",
    "type": "glueful-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Tawiah Sowah",
            "email": "michael@glueful.dev"
        }
    ],
    "keywords": [
        "multi-tenancy",
        "tenancy",
        "row-level",
        "glueful"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "glueful/extension-contracts": "^1.2.0"
    },
    "require-dev": {
        "glueful/framework": "^1.67.0",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.6",
        "phpstan/phpstan": "^1.0"
    },
    "suggest": {
        "glueful/aegis": "RBAC provider that can govern cross-tenant bypass \u2014 grant a role the configured bypass permission (tenancy.access_any / tenancy.manage) to unlock Tenancy::forAnyTenant()."
    },
    "homepage": "https://github.com/glueful/tenancy",
    "autoload": {
        "psr-4": {
            "Glueful\\Extensions\\Tenancy\\": "src/"
        },
        "classmap": [
            "migrations/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Glueful\\Extensions\\Tenancy\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpcs": "vendor/bin/phpcs --standard=PSR12 src",
        "phpcbf": "vendor/bin/phpcbf --standard=PSR12 src",
        "analyze": "vendor/bin/phpstan analyse src"
    },
    "extra": {
        "glueful": {
            "name": "Tenancy",
            "displayName": "Tenancy",
            "description": "Shared-database, row-level multi-tenancy for Glueful.",
            "version": "1.2.0",
            "categories": [
                "multi-tenancy",
                "security"
            ],
            "publisher": "glueful-team",
            "provider": "Glueful\\Extensions\\Tenancy\\TenancyServiceProvider",
            "requires": {
                "glueful": ">=1.67.0",
                "extensions": []
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "repositories": [{
        "name": "extension-contracts",
        "type": "path",
        "url": "../contracts"
    }]
}
